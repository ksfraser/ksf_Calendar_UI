{
    "name": "ksfraser/superglobals",
    "description": "A PHP library for testable superglobal access with SRP design",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Kevin Fraser",
            "email": "kevin@ksfraser.com"
        }
    ],
    "require": {
        "php": ">=7.3.0"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\Superglobals\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\Superglobals\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "keywords": [
        "superglobals",
        "testable",
        "psr-4",
        "php",
        "dependency-injection"
    ],
    "homepage": "https://github.com/ksfraser/superglobals",
    "support": {
        "issues": "https://github.com/ksfraser/superglobals/issues",
        "source": "https://github.com/ksfraser/superglobals"
    }
}