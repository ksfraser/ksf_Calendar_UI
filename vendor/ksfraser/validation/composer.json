{
  "name": "ksfraser/validation",
  "description": "Small validation helpers and traits (PHP 7.3+) for KS Fraser modules migration.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=7.3"
  },
  "autoload": {
    "psr-4": {
      "Ksfraser\\Validation\\": "src/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload-dev": {
    "psr-4": {
      "Ksfraser\\Validation\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "@php vendor/bin/phpunit"
  }
}
