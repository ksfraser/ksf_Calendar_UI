{
    "name": "ksfraser/ksf-calendar-ui",
    "description": "Standalone Calendar UI - FullCalendar.js frontend for ksf_Calendar. Multiple calendar views, drag-and-drop, iCal sync.",
    "type": "library",
    "license": "GPL-3.0",
    "keywords": [
        "calendar",
        "fullcalendar",
        "ui",
        "frontend",
        "dotproject",
        "frontaccounting",
        "ksf"
    ],
    "authors": [
        {
            "name": "KSFII Development Team",
            "email": "dev@ksfii.org"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=7.4",
        "ksfraser/ksf-calendar": "*",
        "ksfraser/genericinterface": "*",
        "ksfraser/superglobals": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\": "src/Ksfraser/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always"
    },
    "config": {
        "sort-packages": true
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packagist.org",
            "canonical": true
        },
        {
            "type": "path",
            "url": "../ksf_Calendar"
        }
    ]
}